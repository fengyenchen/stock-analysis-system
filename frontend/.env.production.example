# Frontend production env (Vercel).
# Copy values into the Vercel project's Environment Variables (Production scope),
# or run `vercel env add VITE_API_URL production`.
#
# Point this at the Cloud Run service base URL. Either form works:
#   VITE_API_URL=https://<service>-<hash>-<region>.a.run.app
#   VITE_API_URL=https://<service>-<hash>-<region>.a.run.app/api/v1
# The client appends /api/v1 automatically if it is missing.
VITE_API_URL=https://REPLACE-ME.a.run.app
