# Application
ENVIRONMENT=development
DEBUG=false

# Security - generate a strong secret key for production
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite example: sqlite:///./app.db
# PostgreSQL example: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://authservice:authservice_password@localhost:5432/auth_db

# CORS - comma separated origins, or * for all
CORS_ORIGINS=*

# AI analysis
# DeepSeek API key used by the backend AI provider. Never expose this in frontend env files.
DEEPSEEK_API_KEY=
AI_ANALYSIS_CACHE_TTL_SECONDS=300
AI_ANALYSIS_PROVIDER_TIMEOUT_SECONDS=20.0
AI_ANALYSIS_MAX_CONCURRENT_JOBS=2
AI_ANALYSIS_MAX_QUEUED_JOBS=20
AI_ANALYSIS_CIRCUIT_FAILURE_THRESHOLD=3
AI_ANALYSIS_CIRCUIT_COOLDOWN_SECONDS=60
AI_ANALYSIS_JOB_STALE_SECONDS=300
